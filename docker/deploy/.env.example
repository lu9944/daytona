### ==================================================
### Daytona + Keycloak Deployment Configuration
### ==================================================
### Copy this file to .env and customize as needed.
### All values below are defaults for local testing.
### CHANGE all passwords and secrets for production!
### ==================================================

### --- Domain Configuration ---
DAYTONA_DOMAIN=daytona.example.com
KEYCLOAK_DOMAIN=auth.example.com
PROXY_DOMAIN=proxy.daytona.example.com

### --- Daytona Build ---
DAYTONA_VERSION=0.0.1
DAYTONA_SRC=../../

### --- Daytona API ---
ENCRYPTION_KEY=supersecretkey
ENCRYPTION_SALT=supersecretsalt
HEALTH_CHECK_API_KEY=supersecretkey

### --- Database (Daytona) ---
DB_USERNAME=daytona
DB_PASSWORD=daytona
DB_DATABASE=daytona

### --- Keycloak ---
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_PASSWORD=keycloak

### --- OIDC ---
OIDC_CLIENT_ID=daytona

### --- Runner ---
RUNNER_API_KEY=secret_api_token
RUNNER_CPU=4
RUNNER_MEMORY=8
RUNNER_DISK=50

### --- Proxy ---
PROXY_API_KEY=super_secret_key

### --- SSH Gateway ---
SSH_GATEWAY_API_KEY=ssh_secret_api_token

### --- SSH Keys (auto-generated by build.sh init) ---
SSH_PRIVATE_KEY=
SSH_HOST_KEY=
SSH_GATEWAY_PUBLIC_KEY=

### --- Email (optional, for password reset etc.) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=
SMTP_EMAIL_FROM=

### --- Telemetry (optional) ---
POSTHOG_API_KEY=
POSTHOG_HOST=
